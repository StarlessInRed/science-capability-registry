{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/capability_registry.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: cross-software capability routing catalog. This catalog references canonical asset cards, run schemas, configs, package entrypoints, and evidence IDs without duplicating scientific facts.",
  "title": "Science Capability Registry Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "registry_id",
    "schema_version",
    "catalog_role",
    "capabilities"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "registry_id": {
      "const": "science_capability_registry.capability_catalog"
    },
    "schema_version": {
      "const": "0.1.0"
    },
    "catalog_role": {
      "const": "capability_routing_and_evidence_index"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability_id",
          "asset_id",
          "software",
          "domain",
          "asset_path",
          "run_schema_path",
          "default_config_path",
          "package_entrypoint",
          "card_status",
          "benchmark_status",
          "evidence_ids"
        ],
        "properties": {
          "capability_id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "asset_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "software": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "asset_path": {
            "$ref": "#/$defs/repo_relative_path"
          },
          "run_schema_path": {
            "$ref": "#/$defs/repo_relative_path"
          },
          "default_config_path": {
            "$ref": "#/$defs/repo_relative_path"
          },
          "package_entrypoint": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.]+:[A-Za-z_][A-Za-z0-9_]*$"
          },
          "card_status": {
            "enum": [
              "draft",
              "review",
              "accepted",
              "retired"
            ]
          },
          "benchmark_status": {
            "enum": [
              "not_applicable",
              "benchmark_candidate",
              "package_skeleton_created",
              "benchmark_validated",
              "validation_failed",
              "retired"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+$"
            },
            "uniqueItems": true
          }
        },
        "not": {
          "anyOf": [
            {"required": ["physics"]},
            {"required": ["inputs"]},
            {"required": ["outputs"]},
            {"required": ["benchmark"]},
            {"required": ["validation_criteria"]},
            {"required": ["reference_observations"]}
          ]
        }
      }
    }
  },
  "$defs": {
    "repo_relative_path": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\)[A-Za-z0-9_./-]+$"
    }
  }
}
