{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/fluent_failure_ledger.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: Fluent C01-C08 failure ledger, prioritization, and recovery queue contract.",
  "title": "Fluent Failure Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ledger_id",
    "schema_version",
    "schema_path",
    "index_role",
    "scope",
    "created_on",
    "source_policy",
    "evidence_levels",
    "work_queue_policy",
    "entries",
    "work_queue"
  ],
  "properties": {
    "ledger_id": {"const": "science_capability_registry.fluent_failure_ledger"},
    "schema_version": {"type": "string", "pattern": "^0\\.1\\.0$"},
    "schema_path": {"const": "schemas/fluent_failure_ledger.schema.json"},
    "index_role": {"const": "failure_classification"},
    "scope": {"const": "Fluent C01-C08"},
    "created_on": {"type": "string", "minLength": 1},
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_sources", "runtime_policy", "conversation_policy", "status_policy"],
      "properties": {
        "canonical_sources": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "runtime_policy": {"type": "string", "minLength": 1},
        "conversation_policy": {"type": "string", "minLength": 1},
        "status_policy": {"type": "string", "minLength": 1}
      }
    },
    "evidence_levels": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1},
      "required": ["repo_stable_report", "runtime_result", "test_code_guard", "conversation_memory"]
    },
    "work_queue_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority_scale", "status_values", "ordering_rule", "closure_rule"],
      "properties": {
        "priority_scale": {
          "type": "object",
          "additionalProperties": false,
          "required": ["P0", "P1", "P2", "P3"],
          "properties": {
            "P0": {"type": "string", "minLength": 1},
            "P1": {"type": "string", "minLength": 1},
            "P2": {"type": "string", "minLength": 1},
            "P3": {"type": "string", "minLength": 1}
          }
        },
        "status_values": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["active", "blocked", "gap", "mitigation_only", "resolved"]}
        },
        "ordering_rule": {"type": "string", "minLength": 1},
        "closure_rule": {"type": "string", "minLength": 1}
      }
    },
    "entries": {
      "type": "array",
      "minItems": 8,
      "items": {"$ref": "#/$defs/entry"}
    },
    "work_queue": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/work_item"}
    }
  },
  "$defs": {
    "repo_path": {
      "type": "string",
      "not": {"pattern": "^[A-Za-z]:|\\\\"}
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "evidence_level"],
      "properties": {
        "evidence_id": {"type": "string", "minLength": 1},
        "evidence_level": {"enum": ["repo_stable_report", "runtime_result", "test_code_guard"]}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_id",
        "cxx_group",
        "capability_id",
        "asset_path",
        "state",
        "failure_class",
        "priority",
        "work_queue_status",
        "gate_blocked",
        "benchmark_status_effect",
        "summary",
        "owner_next_action",
        "blocked_by",
        "evidence_refs",
        "closure_criteria",
        "do_not_claim",
        "confidence",
        "last_reviewed"
      ],
      "properties": {
        "failure_id": {"type": "string", "pattern": "^FL-C[0-9]{2}-"},
        "cxx_group": {"enum": ["C01", "C02", "C03", "C04", "C05", "C06", "C07", "C08"]},
        "capability_id": {"type": "string", "pattern": "^cfd\\.fluent\\."},
        "asset_path": {"$ref": "#/$defs/repo_path"},
        "state": {"type": "string", "minLength": 1},
        "failure_class": {"type": "string", "minLength": 1},
        "priority": {"enum": ["P0", "P1", "P2", "P3"]},
        "work_queue_status": {"enum": ["active", "blocked", "gap", "mitigation_only", "resolved"]},
        "gate_blocked": {"type": "string", "minLength": 1},
        "benchmark_status_effect": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "owner_next_action": {"type": "string", "minLength": 1},
        "blocked_by": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence_ref"}},
        "runtime_evidence_paths": {"type": "array", "items": {"$ref": "#/$defs/repo_path"}},
        "closure_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "do_not_claim": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "confidence": {"enum": ["high", "medium", "low"]},
        "last_reviewed": {"type": "string", "minLength": 1}
      }
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_id",
        "priority",
        "entry_failure_ids",
        "title",
        "action",
        "acceptance_checks",
        "expected_evidence"
      ],
      "properties": {
        "queue_id": {"type": "string", "pattern": "^FL-WQ-[0-9]{3}$"},
        "priority": {"enum": ["P0", "P1", "P2", "P3"]},
        "entry_failure_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^FL-C[0-9]{2}-"}},
        "title": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "acceptance_checks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "expected_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/repo_path"}}
      }
    }
  }
}
