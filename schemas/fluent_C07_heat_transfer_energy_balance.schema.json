{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/fluent_C07_heat_transfer_energy_balance.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: Fluent C07 heat-transfer case/data source readiness config.",
  "title": "Fluent C07 Heat Transfer Energy Balance Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "source_root",
    "backend",
    "source_package",
    "thermal_scope",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {"const": "cfd.fluent.heat_transfer_energy_balance"},
    "case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "description": {"type": "string", "minLength": 1},
    "source_root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_root_env", "logical_path"],
      "properties": {
        "source_root_env": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "logical_path": {"type": "string", "pattern": "^(?!/)(?!.*:)(?!.*\\\\)[A-Za-z0-9_./+-]+$"}
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "archive_access"],
      "properties": {
        "type": {"const": "case_data_manifest"},
        "archive_access": {"const": "read_only_zip"}
      }
    },
    "source_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "rel_path", "package_role"],
      "properties": {
        "source_id": {"const": "C07_heat_exchanger"},
        "rel_path": {"const": "Fluent_Tutorial_Package/2d_heat_exchanger_optimizer.zip"},
        "package_role": {"type": "string", "minLength": 1}
      }
    },
    "thermal_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_class", "readiness_scope", "future_runtime_metrics", "no_homology_claims"],
      "properties": {
        "model_class": {"type": "string", "minLength": 1},
        "readiness_scope": {"type": "string", "minLength": 1},
        "future_runtime_metrics": {"$ref": "#/$defs/non_empty_string_array"},
        "no_homology_claims": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "expected_outputs"],
      "properties": {
        "output_dir": {"type": "string", "minLength": 1},
        "expected_outputs": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "required_entry_classes", "min_case_data_pairs", "required_artifacts", "no_claims"],
      "properties": {
        "gate": {"const": "static-readiness"},
        "required_entry_classes": {
          "type": "array",
          "items": {"enum": ["case", "data"]},
          "minItems": 2,
          "uniqueItems": true
        },
        "min_case_data_pairs": {"type": "integer", "minimum": 1},
        "required_artifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        },
        "no_claims": {"$ref": "#/$defs/non_empty_string_array"}
      }
    }
  },
  "$defs": {
    "artifact_name": {
      "enum": [
        "heat_transfer_source_manifest.json",
        "case_data_entries.json",
        "metrics.json",
        "validation.json",
        "validation_report.md",
        "manifest.json"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    }
  }
}
