{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_C01_lid_driven_cavity_incompressible_laminar.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: OpenFOAM C01 lid-driven cavity run config; producer: capability owners and interns; consumer: dry-run runner, backend runner, validation reviewers; failure behavior: reject unknown keys and missing scientific choices.",
  "title": "OpenFOAM C01 Lid-Driven Cavity Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "openfoam",
    "backend",
    "solver",
    "geometry",
    "mesh",
    "material",
    "fields",
    "numerics",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "cfd.openfoam.lid_driven_cavity_incompressible_laminar"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "openfoam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution",
        "version",
        "runtime_profile",
        "tutorial_path",
        "source_url"
      ],
      "properties": {
        "distribution": {
          "enum": [
            "openfoam_com",
            "openfoam_foundation",
            "openfoam_dev",
            "unknown"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "runtime_profile": {
          "type": "string",
          "minLength": 1
        },
        "tutorial_path": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "bashrc_path": {
          "type": "string",
          "minLength": 1
        },
        "case_layout": {
          "enum": [
            "single_region"
          ]
        },
        "required_executables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "dry_run_only",
            "native_linux",
            "wsl",
            "docker"
          ]
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "parallel": {
          "type": "boolean"
        },
        "wsl_distro": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "solver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "mode",
        "command_sequence"
      ],
      "properties": {
        "name": {
          "const": "icoFoam"
        },
        "mode": {
          "const": "transient_incompressible_laminar"
        },
        "command_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cavity_side_length_m",
        "thickness_m"
      ],
      "properties": {
        "cavity_side_length_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "thickness_m": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "mesh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator",
        "cells",
        "simple_grading",
        "patches"
      ],
      "properties": {
        "generator": {
          "const": "blockMesh"
        },
        "cells": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "integer",
              "const": 1
            }
          ],
          "items": false
        },
        "simple_grading": {
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "type": "number",
              "exclusiveMinimum": 0
            }
          ],
          "items": false
        },
        "patches": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "movingWall",
            "fixedWalls",
            "frontAndBack"
          ],
          "properties": {
            "movingWall": {
              "$ref": "#/$defs/patch"
            },
            "fixedWalls": {
              "$ref": "#/$defs/patch"
            },
            "frontAndBack": {
              "$ref": "#/$defs/patch"
            }
          }
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kinematic_viscosity_m2_s",
        "reynolds_number",
        "lid_velocity_m_s"
      ],
      "properties": {
        "kinematic_viscosity_m2_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "reynolds_number": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "lid_velocity_m_s": {
          "type": "number"
        }
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p",
        "U"
      ],
      "properties": {
        "p": {
          "$ref": "#/$defs/field"
        },
        "U": {
          "$ref": "#/$defs/field"
        }
      }
    },
    "numerics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control",
        "fv_schemes",
        "fv_solution"
      ],
      "properties": {
        "control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start_time_s",
            "end_time_s",
            "delta_t_s",
            "write_interval"
          ],
          "properties": {
            "start_time_s": {
              "type": "number"
            },
            "end_time_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "delta_t_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "write_interval": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "fv_schemes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ddt",
            "grad",
            "div_phi_U",
            "laplacian",
            "interpolation",
            "sn_grad"
          ],
          "properties": {
            "ddt": {
              "type": "string",
              "minLength": 1
            },
            "grad": {
              "type": "string",
              "minLength": 1
            },
            "div_phi_U": {
              "type": "string",
              "minLength": 1
            },
            "laplacian": {
              "type": "string",
              "minLength": 1
            },
            "interpolation": {
              "type": "string",
              "minLength": 1
            },
            "sn_grad": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "fv_solution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "p_solver",
            "p_final_solver",
            "U_solver",
            "piso"
          ],
          "properties": {
            "p_solver": {
              "$ref": "#/$defs/linear_solver"
            },
            "U_solver": {
              "$ref": "#/$defs/linear_solver"
            },
            "piso": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "nCorrectors",
                "nNonOrthogonalCorrectors",
                "pRefCell",
                "pRefValue"
              ],
              "properties": {
                "nCorrectors": {
                  "type": "integer",
                  "minimum": 1
                },
                "nNonOrthogonalCorrectors": {
                  "type": "integer",
                  "minimum": 0
                },
                "pRefCell": {
                  "type": "integer",
                  "minimum": 0
                },
                "pRefValue": {
                  "type": "number"
                }
              }
            },
            "p_final_solver": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "base",
                "relTol"
              ],
              "properties": {
                "base": {
                  "const": "p"
                },
                "relTol": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "retain_generated_case",
        "expected_outputs",
        "postprocess"
      ],
      "properties": {
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "retain_generated_case": {
          "type": "boolean"
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "postprocess": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "centerline_profiles",
            "plots"
          ],
          "properties": {
            "centerline_profiles": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "plots": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "max_courant_number",
        "required_generated_files",
        "required_manifest_sections"
      ],
      "properties": {
        "gate": {
          "enum": [
            "static-readiness",
            "smoke",
            "targeted-regression",
            "integration",
            "double-v",
            "full-regression"
          ]
        },
        "max_courant_number": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required_generated_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_manifest_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "matrix_role": {
          "enum": [
            "baseline",
            "mesh_refinement",
            "reynolds_increase",
            "timestep_refinement"
          ]
        },
        "compare_to": {
          "type": "string",
          "minLength": 1
        },
        "expected_trend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "primary_metric": {
              "type": "string",
              "minLength": 1
            },
            "direction": {
              "type": "string",
              "minLength": 1
            },
            "threshold": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "role"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "dimensions",
        "internal_field",
        "boundaries"
      ],
      "properties": {
        "class": {
          "enum": [
            "volScalarField",
            "volVectorField"
          ]
        },
        "dimensions": {
          "type": "string",
          "minLength": 1
        },
        "internal_field": {
          "type": "string",
          "minLength": 1
        },
        "boundaries": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              }
            }
          },
          "minProperties": 1
        }
      }
    },
    "linear_solver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solver",
        "tolerance",
        "relTol"
      ],
      "properties": {
        "solver": {
          "type": "string",
          "minLength": 1
        },
        "preconditioner": {
          "type": "string"
        },
        "smoother": {
          "type": "string"
        },
        "tolerance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "relTol": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
