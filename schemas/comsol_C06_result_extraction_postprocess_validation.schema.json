{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/comsol_C06_result_extraction_postprocess_validation.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: COMSOL C06 static result-extraction and postprocess handoff contract.",
  "title": "COMSOL C06 Result Extraction Postprocess Validation Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["capability_id", "asset_id", "case_id", "description", "depends_on", "backend", "contract", "outputs", "validation"],
  "properties": {
    "capability_id": {"const": "multiphysics.comsol.result_extraction_postprocess_validation"},
    "asset_id": {"const": "C06_result_extraction_postprocess_validation"},
    "case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "description": {"type": "string", "minLength": 1},
    "depends_on": {"type": "array", "items": {"const": "multiphysics.comsol.study_run_solver_smoke"}, "maxItems": 1},
    "backend": {"$ref": "#/$defs/backend"},
    "contract": {"$ref": "#/$defs/contract"},
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "expected_outputs"],
      "properties": {
        "output_dir": {"type": "string", "pattern": "^_results/comsol/result_extraction_postprocess_validation/[A-Za-z0-9_./-]+$"},
        "expected_outputs": {"$ref": "#/$defs/expected_outputs"}
      }
    },
    "validation": {"$ref": "#/$defs/validation"}
  },
  "$defs": {
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "timeout_s"],
      "properties": {"type": {"const": "dry_run_only"}, "timeout_s": {"type": "number", "exclusiveMinimum": 0}}
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "scope", "source_boundary", "declared_objects", "artifacts", "handoff_contract"],
      "properties": {
        "stage": {"const": "result_extraction_postprocess_validation"},
        "scope": {"type": "string", "minLength": 1},
        "source_boundary": {"type": "string", "minLength": 1},
        "declared_objects": {"$ref": "#/$defs/declared_objects"},
        "artifacts": {"$ref": "#/$defs/artifacts"},
        "handoff_contract": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}
      }
    },
    "declared_objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "required", "description"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Za-z0-9_./-]+$"},
          "role": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
          "required": {"type": "boolean"},
          "description": {"type": "string", "minLength": 1}
        }
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "required"],
        "properties": {
          "path": {"enum": ["export_manifest.json", "probes.csv", "units.json"]},
          "role": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"}
        }
      },
      "minItems": 3,
      "uniqueItems": true
    },
    "expected_outputs": {
      "type": "array",
      "items": {"enum": ["export_manifest.json", "probes.csv", "units.json", "manifest.json", "metrics.json", "validation.json", "validation_report.md"]},
      "minItems": 7,
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "required_object_roles", "required_manifest_sections", "required_artifacts", "no_claims"],
      "properties": {
        "gate": {"const": "static-readiness"},
        "required_object_roles": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9_-]+$"}, "minItems": 1, "uniqueItems": true},
        "required_manifest_sections": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
        "required_artifacts": {"$ref": "#/$defs/expected_outputs"},
        "no_claims": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}
      }
    }
  }
}
