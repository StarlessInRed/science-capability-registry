{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_C03_backward_facing_step_rans_internal_flow.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: OpenFOAM C03 backward-facing step RANS run config.",
  "title": "OpenFOAM C03 Backward-Facing Step RANS Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "openfoam",
    "backend",
    "solver",
    "template",
    "geometry",
    "mesh",
    "material",
    "turbulence",
    "numerics",
    "postprocess",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "cfd.openfoam.backward_facing_step_rans_internal_flow"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "openfoam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution",
        "version",
        "runtime_profile",
        "tutorial_path",
        "source_url",
        "bashrc_path",
        "required_executables"
      ],
      "properties": {
        "distribution": {
          "enum": [
            "openfoam_com",
            "openfoam_foundation",
            "openfoam_dev",
            "unknown"
          ]
        },
        "version": {
          "type": "string"
        },
        "runtime_profile": {
          "type": "string"
        },
        "tutorial_path": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "bashrc_path": {
          "type": "string"
        },
        "case_layout": {
          "enum": [
            "single_region"
          ]
        },
        "required_executables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "dry_run_only",
            "wsl"
          ]
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "parallel": {
          "type": "boolean"
        },
        "wsl_distro": {
          "type": "string"
        }
      }
    },
    "solver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "mode",
        "command_sequence"
      ],
      "properties": {
        "name": {
          "const": "simpleFoam"
        },
        "mode": {
          "const": "steady_incompressible_RANS"
        },
        "command_sequence": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "copy_strategy",
        "disabled_function_objects"
      ],
      "properties": {
        "source_path": {
          "type": "string"
        },
        "copy_strategy": {
          "const": "copy_official_tutorial_then_patch"
        },
        "disabled_function_objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_height_m",
        "step_location_x_m"
      ],
      "properties": {
        "step_height_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "step_location_x_m": {
          "type": "number"
        }
      }
    },
    "mesh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator",
        "cell_count_scale"
      ],
      "properties": {
        "generator": {
          "const": "blockMesh"
        },
        "cell_count_scale": {
          "type": "number",
          "minimum": 1
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kinematic_viscosity_m2_s",
        "density_kg_m3",
        "inlet_velocity_m_s",
        "reynolds_number_H"
      ],
      "properties": {
        "kinematic_viscosity_m2_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "density_kg_m3": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "inlet_velocity_m_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "reynolds_number_H": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "turbulence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "k_m2_s2",
        "epsilon_m2_s3"
      ],
      "properties": {
        "model": {
          "const": "kEpsilon"
        },
        "k_m2_s2": {
          "type": "number",
          "minimum": 0
        },
        "epsilon_m2_s3": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "numerics": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "control"
      ],
      "properties": {
        "control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "end_time_iterations",
            "write_interval"
          ],
          "properties": {
            "end_time_iterations": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "write_interval": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "postprocess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "velocity_profile_x_over_H",
        "wall_patch",
        "method_note"
      ],
      "properties": {
        "velocity_profile_x_over_H": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "wall_patch": {
          "const": "lowerWall"
        },
        "method_note": {
          "type": "string"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "retain_generated_case",
        "expected_outputs"
      ],
      "properties": {
        "output_dir": {
          "type": "string"
        },
        "retain_generated_case": {
          "type": "boolean"
        },
        "expected_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "max_final_residual",
        "max_continuity_sum_local",
        "required_generated_files",
        "required_manifest_sections",
        "matrix_role",
        "expected_trend"
      ],
      "properties": {
        "gate": {
          "enum": [
            "static-readiness",
            "smoke",
            "targeted-regression",
            "integration",
            "double-v",
            "full-regression"
          ]
        },
        "max_final_residual": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_continuity_sum_local": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required_generated_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_manifest_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matrix_role": {
          "enum": [
            "baseline",
            "mesh_refinement",
            "inlet_velocity_high",
            "inlet_velocity_low"
          ]
        },
        "compare_to": {
          "type": "string"
        },
        "expected_trend": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
