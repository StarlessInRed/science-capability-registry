{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_runtime_evidence_manifest.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: shared OpenFOAM runtime-evidence manifest envelope. Capability-specific physics metrics remain in each Cxx schema, metrics.json, and postprocess outputs.",
  "title": "OpenFOAM Runtime Evidence Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "capability_id",
    "case_id",
    "source_config",
    "schema_id",
    "output_dir",
    "openfoam",
    "backend",
    "solver",
    "generated_files",
    "solver_commands",
    "postprocess_commands",
    "expected_outputs",
    "validation_targets",
    "scope"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "pattern": "^cfd\\.openfoam\\.[a-z0-9_.-]+$"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "source_config": {
      "type": ["string", "null"]
    },
    "schema_id": {
      "$ref": "#/$defs/repo_relative_json_path"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "openfoam": {
      "type": "object",
      "required": ["runtime_profile"],
      "properties": {
        "runtime_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "backend": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["dry_run_only", "native_linux", "wsl", "docker"]
        }
      }
    },
    "solver": {
      "type": "object",
      "required": ["name", "command_sequence"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "generated_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mesh_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "solver_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "postprocess_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_targets": {
      "type": "object",
      "required": ["gate"],
      "properties": {
        "gate": {
          "enum": [
            "static-readiness",
            "smoke",
            "targeted-regression",
            "integration",
            "double-v",
            "full-regression"
          ]
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["passed", "gate", "scope", "checks"],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "gate": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "checks": {
          "type": "array"
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": [
        "backend",
        "commands",
        "metrics_json",
        "validation_json"
      ],
      "properties": {
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "wsl_distro": {
          "type": "string"
        },
        "bashrc_path": {
          "type": "string"
        },
        "profile_env": {
          "type": "object"
        },
        "commands": {
          "type": "array",
          "minItems": 1
        },
        "metrics_json": {
          "type": "string",
          "minLength": 1
        },
        "validation_json": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "repo_relative_json_path": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\)[A-Za-z0-9_./-]+\\.json$"
    }
  }
}
