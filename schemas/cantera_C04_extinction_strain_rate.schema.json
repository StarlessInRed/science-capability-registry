{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/cantera_C04_extinction_strain_rate.schema.json",
  "title": "Cantera C04 Extinction Strain Rate Run Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "mechanism",
    "pressure_pa",
    "width_m",
    "fuel_inlet",
    "oxidizer_inlet",
    "refine_criteria",
    "scaling_exponents",
    "extinction_search",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "combustion.cantera.extinction_strain_rate"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "description": {
      "type": "string"
    },
    "source_asset": {
      "type": "string"
    },
    "mechanism": {
      "type": "string",
      "minLength": 1
    },
    "pressure_pa": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "width_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "loglevel": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "stoichiometric_fuel_species": {
      "type": "string",
      "minLength": 1
    },
    "fuel_inlet": {
      "$ref": "#/$defs/inlet"
    },
    "oxidizer_inlet": {
      "$ref": "#/$defs/inlet"
    },
    "refine_criteria": {
      "$ref": "#/$defs/refine_criteria"
    },
    "scaling_exponents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid", "velocity", "spread_rate", "radial_pressure_gradient", "mass_flux"],
      "properties": {
        "grid": {"type": "number"},
        "velocity": {"type": "number"},
        "spread_rate": {"type": "number"},
        "radial_pressure_gradient": {"type": "number"},
        "mass_flux": {"type": "number"}
      }
    },
    "extinction_search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_delta_alpha",
        "delta_alpha_factor",
        "delta_alpha_min",
        "delta_temperature_min_k",
        "max_iterations"
      ],
      "properties": {
        "initial_delta_alpha": {"type": "number", "exclusiveMinimum": 0},
        "delta_alpha_factor": {"type": "number", "exclusiveMinimum": 1},
        "delta_alpha_min": {"type": "number", "exclusiveMinimum": 0},
        "delta_temperature_min_k": {"type": "number", "exclusiveMinimum": 0},
        "max_iterations": {"type": "integer", "minimum": 1}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "save_solution_snapshots",
        "save_csv",
        "save_plots",
        "save_log",
        "save_metrics",
        "save_validation_report"
      ],
      "properties": {
        "output_dir": {"type": "string", "minLength": 1},
        "save_solution_snapshots": {"type": "boolean"},
        "save_csv": {"type": "boolean"},
        "save_plots": {"type": "boolean"},
        "save_log": {"type": "boolean"},
        "save_metrics": {"type": "boolean"},
        "save_validation_report": {"type": "boolean"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "extinction_peak_temperature_k",
        "max_strain_rate_1_s",
        "min_burning_solution_count"
      ],
      "properties": {
        "extinction_peak_temperature_k": {"$ref": "#/$defs/range"},
        "max_strain_rate_1_s": {"$ref": "#/$defs/range"},
        "min_burning_solution_count": {"type": "integer", "minimum": 1}
      }
    }
  },
  "$defs": {
    "inlet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature_k", "mass_flux_kg_m2_s", "composition"],
      "properties": {
        "temperature_k": {"type": "number", "exclusiveMinimum": 0},
        "mass_flux_kg_m2_s": {"type": "number", "exclusiveMinimum": 0},
        "composition": {"type": "string", "minLength": 1}
      }
    },
    "refine_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratio", "slope", "curve", "prune"],
      "properties": {
        "ratio": {"type": "number", "exclusiveMinimum": 1},
        "slope": {"type": "number", "minimum": 0, "maximum": 1},
        "curve": {"type": "number", "minimum": 0, "maximum": 1},
        "prune": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number"},
        "max": {"type": "number"}
      }
    }
  }
}
