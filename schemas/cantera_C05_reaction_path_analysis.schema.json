{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/cantera_C05_reaction_path_analysis.schema.json",
  "title": "Cantera C05 Reaction Path Analysis Run Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "mechanism",
    "reactor_model",
    "initial_temperature_k",
    "pressure_pa",
    "composition",
    "target_temperature_k",
    "max_time_s",
    "max_steps",
    "element",
    "diagram",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "combustion.cantera.reaction_path_analysis"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "description": {
      "type": "string"
    },
    "source_asset": {
      "type": "string"
    },
    "mechanism": {
      "type": "string",
      "minLength": 1
    },
    "reactor_model": {
      "const": "ideal_gas_constant_volume"
    },
    "initial_temperature_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "pressure_pa": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "composition": {
      "type": "string",
      "minLength": 1
    },
    "target_temperature_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_time_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "max_steps": {
      "type": "integer",
      "minimum": 1
    },
    "element": {
      "type": "string",
      "pattern": "^[A-Z][a-z]?$"
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label_threshold", "title"],
      "properties": {
        "label_threshold": {"type": "number", "minimum": 0},
        "title": {"type": "string", "minLength": 1}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "save_dot",
        "save_graph_png",
        "save_data_txt",
        "save_csv",
        "save_flux_plot",
        "save_log",
        "save_metrics",
        "save_validation_report"
      ],
      "properties": {
        "output_dir": {"type": "string", "minLength": 1},
        "save_dot": {"type": "boolean"},
        "save_graph_png": {"type": "boolean"},
        "save_data_txt": {"type": "boolean"},
        "save_csv": {"type": "boolean"},
        "save_flux_plot": {"type": "boolean"},
        "save_log": {"type": "boolean"},
        "save_metrics": {"type": "boolean"},
        "save_validation_report": {"type": "boolean"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_temperature_k",
        "max_final_time_s",
        "min_step_count",
        "min_node_count",
        "min_edge_count",
        "min_significant_edge_count",
        "significant_flux_threshold",
        "min_max_abs_net_flux",
        "expected_nodes"
      ],
      "properties": {
        "final_temperature_k": {"$ref": "#/$defs/range"},
        "max_final_time_s": {"type": "number", "exclusiveMinimum": 0},
        "min_step_count": {"type": "integer", "minimum": 1},
        "min_node_count": {"type": "integer", "minimum": 1},
        "min_edge_count": {"type": "integer", "minimum": 1},
        "min_significant_edge_count": {"type": "integer", "minimum": 1},
        "significant_flux_threshold": {"type": "number", "minimum": 0},
        "min_max_abs_net_flux": {"type": "number", "minimum": 0},
        "expected_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number"},
        "max": {"type": "number"}
      }
    }
  }
}
