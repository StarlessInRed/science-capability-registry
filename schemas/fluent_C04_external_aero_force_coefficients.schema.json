{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/fluent_C04_external_aero_force_coefficients.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: Fluent C04 external-aero reference CSV parser config.",
  "title": "Fluent C04 External Aero Force Coefficients Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "source_root",
    "backend",
    "source_package",
    "governing_model",
    "outputs",
    "reference_csvs",
    "validation"
  ],
  "properties": {
    "capability_id": {"const": "cfd.fluent.external_aero_force_coefficients"},
    "case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "description": {"type": "string", "minLength": 1},
    "source_root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_root_env", "logical_path"],
      "properties": {
        "source_root_env": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "logical_path": {"type": "string", "pattern": "^(?!/)(?!.*:)(?!.*\\\\)[A-Za-z0-9_./+-]+$"}
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "archive_access"],
      "properties": {
        "type": {"enum": ["reference_csv_parser", "fluent_case_read_smoke"]},
        "archive_access": {"const": "read_only_zip"},
        "timeout_s": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "fluent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_profile", "runtime_profile_config", "vendor", "product", "version_family", "executable_env", "dimension_precision", "headless_flags", "processor_count", "journal_argument"],
      "properties": {
        "runtime_profile": {"const": "local_fluent_preflight"},
        "runtime_profile_config": {"type": "string", "minLength": 1},
        "vendor": {"const": "Ansys"},
        "product": {"const": "Fluent"},
        "version_family": {"type": "string", "minLength": 1},
        "executable_env": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "dimension_precision": {"enum": ["2ddp", "3ddp"]},
        "headless_flags": {
          "type": "array",
          "items": {"enum": ["-g"]},
          "minItems": 1,
          "uniqueItems": true
        },
        "processor_count": {"type": "integer", "minimum": 1},
        "journal_argument": {"const": "-i"}
      }
    },
    "runtime_smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_entry", "journal_file", "max_warning_count", "scope"],
      "properties": {
        "case_entry": {"type": "string", "pattern": "^[A-Za-z0-9_./+-]+\\.cas\\.h5$"},
        "journal_file": {"const": "journal.jou"},
        "max_warning_count": {"type": "integer", "minimum": 0},
        "scope": {"type": "string", "minLength": 1}
      }
    },
    "source_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "rel_path", "package_role"],
      "properties": {
        "source_id": {"const": "C04_aero_tutorial"},
        "rel_path": {"const": "Fluent_Tutorial_Package/fluent_aero_tutorial.zip"},
        "package_role": {"type": "string", "minLength": 1}
      }
    },
    "governing_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_class", "solver_context", "reference_scope", "homology_requirements"],
      "properties": {
        "model_class": {"type": "string", "minLength": 1},
        "solver_context": {"type": "string", "minLength": 1},
        "reference_scope": {"type": "string", "minLength": 1},
        "homology_requirements": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "expected_outputs"],
      "properties": {
        "output_dir": {"type": "string", "minLength": 1},
        "expected_outputs": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        }
      }
    },
    "reference_csvs": {
      "type": "array",
      "items": {"$ref": "#/$defs/reference_csv"},
      "minItems": 3
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "required_entry_classes",
        "required_artifacts",
        "required_reference_roles",
        "trend_checks",
        "no_claims"
      ],
      "properties": {
        "gate": {"enum": ["static-readiness", "smoke"]},
        "required_entry_classes": {
          "type": "array",
          "items": {
            "enum": [
              "case",
              "mesh",
              "data",
              "journal",
              "reference_csv",
              "design_or_table_csv",
              "workbench_archive"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_artifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        },
        "required_reference_roles": {
          "type": "array",
          "items": {"enum": ["lift_curve", "pressure_coefficient_section"]},
          "minItems": 2,
          "uniqueItems": true
        },
        "trend_checks": {
          "type": "array",
          "items": {"enum": ["lift_curve_cl_monotonic_non_decreasing"]},
          "minItems": 1,
          "uniqueItems": true
        },
        "no_claims": {"$ref": "#/$defs/non_empty_string_array"}
      }
    }
  },
  "$defs": {
    "artifact_name": {
      "enum": [
        "aero_reference_manifest.json",
        "reference_tables.json",
        "IRT-Swept-Tail-Wing.cas.h5",
        "journal.jou",
        "stdout.txt",
        "stderr.txt",
        "transcript.txt",
        "metrics.json",
        "validation.json",
        "validation_report.md",
        "manifest.json"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "reference_csv": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_id",
        "reference_role",
        "entry_path",
        "required_columns",
        "min_rows"
      ],
      "properties": {
        "reference_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "reference_role": {"enum": ["lift_curve", "pressure_coefficient_section"]},
        "entry_path": {"type": "string", "pattern": "^[A-Za-z0-9_./+ -]+\\.csv$"},
        "required_columns": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 2,
          "uniqueItems": true
        },
        "min_rows": {"type": "integer", "minimum": 1}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"backend": {"properties": {"type": {"const": "fluent_case_read_smoke"}}}}},
      "then": {
        "required": ["fluent", "runtime_smoke"],
        "properties": {
          "validation": {
            "properties": {
              "gate": {"const": "smoke"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"backend": {"properties": {"type": {"const": "reference_csv_parser"}}}}},
      "then": {
        "properties": {
          "validation": {
            "properties": {
              "gate": {"const": "static-readiness"}
            }
          }
        }
      }
    }
  ]
}
