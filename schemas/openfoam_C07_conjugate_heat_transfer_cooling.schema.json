{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_C07_conjugate_heat_transfer_cooling.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: OpenFOAM C07 conjugate heat-transfer cooling run config.",
  "title": "OpenFOAM C07 Conjugate Heat Transfer Cooling Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "openfoam",
    "backend",
    "solver",
    "template",
    "regions",
    "mesh_workflow",
    "parallel",
    "materials",
    "fields",
    "interfaces",
    "heat_sources",
    "radiation",
    "numerics",
    "postprocess",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "cfd.openfoam.conjugate_heat_transfer_cooling"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "openfoam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution",
        "version",
        "runtime_profile",
        "tutorial_path",
        "source_url",
        "bashrc_path",
        "case_layout",
        "required_executables"
      ],
      "properties": {
        "distribution": {
          "const": "openfoam_com"
        },
        "version": {
          "const": "v2112"
        },
        "runtime_profile": {
          "const": "openfoam_com_v2112_cht"
        },
        "tutorial_path": {
          "enum": [
            "$FOAM_TUTORIALS/heatTransfer/chtMultiRegionSimpleFoam/cpuCabinet",
            "$FOAM_TUTORIALS/heatTransfer/chtMultiRegionSimpleFoam/multiRegionHeaterRadiation"
          ]
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "bashrc_path": {
          "const": "/opt/OpenFOAM-v2112/etc/bashrc"
        },
        "case_layout": {
          "const": "legacy_cht_multi_region"
        },
        "required_executables": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "timeout_s",
        "parallel",
        "wsl_distro"
      ],
      "properties": {
        "type": {
          "enum": [
            "dry_run_only",
            "wsl"
          ]
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "parallel": {
          "type": "boolean"
        },
        "wsl_distro": {
          "const": "Ubuntu-24.04"
        }
      }
    },
    "solver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "mode",
        "command_sequence"
      ],
      "properties": {
        "name": {
          "const": "chtMultiRegionSimpleFoam"
        },
        "mode": {
          "const": "steady_multi_region_CHT"
        },
        "command_sequence": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_profile_key",
        "source_path",
        "copy_strategy",
        "disabled_function_objects"
      ],
      "properties": {
        "source_profile_key": {
          "enum": [
            "c07_cpu_cabinet",
            "c07_multi_region_heater_radiation"
          ]
        },
        "source_path": {
          "enum": [
            "/opt/OpenFOAM-v2112/tutorials/heatTransfer/chtMultiRegionSimpleFoam/cpuCabinet",
            "/opt/OpenFOAM-v2112/tutorials/heatTransfer/chtMultiRegionSimpleFoam/multiRegionHeaterRadiation"
          ]
        },
        "geometry_resource_path": {
          "type": "string",
          "minLength": 1
        },
        "copy_strategy": {
          "const": "copy_official_tutorial_then_patch"
        },
        "disabled_function_objects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "regions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fluid",
        "solid"
      ],
      "properties": {
        "fluid": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "solid": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "mesh_workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geometry_resource",
        "command_sequence",
        "required_generated_files"
      ],
      "properties": {
        "geometry_resource": {
          "type": "string",
          "minLength": 1
        },
        "command_sequence": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "required_generated_files": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "parallel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "launcher",
        "number_of_subdomains",
        "method",
        "region_subdomains"
      ],
      "properties": {
        "launcher": {
          "const": "mpirun"
        },
        "number_of_subdomains": {
          "type": "integer",
          "minimum": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "region_subdomains": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "materials": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/$defs/fluid_material"
          },
          {
            "$ref": "#/$defs/solid_material"
          }
        ]
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_temperature_K",
        "required_by_region"
      ],
      "properties": {
        "initial_temperature_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required_by_region": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/non_empty_string_array"
          }
        }
      }
    },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "owner_region",
          "neighbour_region",
          "owner_patch",
          "neighbour_patch",
          "temperature_bc"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "owner_region": {
            "type": "string",
            "minLength": 1
          },
          "neighbour_region": {
            "type": "string",
            "minLength": 1
          },
          "owner_patch": {
            "type": "string",
            "minLength": 1
          },
          "neighbour_patch": {
            "type": "string",
            "minLength": 1
          },
          "temperature_bc": {
            "const": "compressible::turbulentTemperatureRadCoupledMixed"
          }
        }
      }
    },
    "heat_sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/heat_source"
      }
    },
    "radiation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "view_factor_regions",
        "preprocessing_commands",
        "required_generated_files"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "view_factor_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "preprocessing_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_generated_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "numerics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control"
      ],
      "properties": {
        "control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "end_time_iterations",
            "delta_t",
            "write_interval",
            "write_format"
          ],
          "properties": {
            "end_time_iterations": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "delta_t": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "write_interval": {
              "type": "integer",
              "minimum": 1
            },
            "write_format": {
              "const": "ascii"
            }
          }
        },
        "mrf": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "omega_rad_s"
          ],
          "properties": {
            "omega_rad_s": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        }
      }
    },
    "postprocess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region_temperature_summary",
        "interface_balance_summary",
        "command_sequence",
        "method_note"
      ],
      "properties": {
        "region_temperature_summary": {
          "type": "boolean"
        },
        "interface_balance_summary": {
          "type": "boolean"
        },
        "command_sequence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "method_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "retain_generated_case",
        "expected_outputs"
      ],
      "properties": {
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "retain_generated_case": {
          "type": "boolean"
        },
        "expected_outputs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "temperature_min_K",
        "temperature_max_K",
        "max_interface_temperature_jump_K",
        "max_interface_heat_flux_relative_mismatch",
        "max_final_residual",
        "required_generated_files",
        "required_manifest_sections",
        "required_interface_pairs",
        "matrix_role",
        "expected_trend"
      ],
      "properties": {
        "gate": {
          "enum": [
            "static-readiness",
            "smoke",
            "targeted-regression",
            "integration",
            "double-v",
            "full-regression"
          ]
        },
        "temperature_min_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "temperature_max_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_interface_temperature_jump_K": {
          "type": "number",
          "minimum": 0
        },
        "max_interface_heat_flux_relative_mismatch": {
          "type": "number",
          "minimum": 0
        },
        "max_final_residual": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required_generated_files": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "required_manifest_sections": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "required_interface_pairs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "matrix_role": {
          "enum": [
            "baseline",
            "heat_power_high",
            "heater_temperature_high",
            "airflow_high",
            "ambient_temperature_high",
            "mesh_refinement",
            "decomposition_sensitivity"
          ]
        },
        "expected_trend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "primary_metric": {
              "type": "string",
              "minLength": 1
            },
            "direction": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fluid_material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thermo_type",
        "mol_weight",
        "cp_J_kg_K",
        "dynamic_viscosity_Pa_s",
        "prandtl"
      ],
      "properties": {
        "thermo_type": {
          "const": "heRhoThermo"
        },
        "mol_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cp_J_kg_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "dynamic_viscosity_Pa_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "prandtl": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "solid_material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thermo_type",
        "density_kg_m3",
        "cp_J_kg_K",
        "thermal_conductivity_W_m_K"
      ],
      "properties": {
        "thermo_type": {
          "const": "heSolidThermo"
        },
        "density_kg_m3": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cp_J_kg_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "thermal_conductivity_W_m_K": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "heat_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "field"
      ],
      "properties": {
        "source_type": {
          "enum": [
            "scalarSemiImplicitSource",
            "fixed_temperature_boundary"
          ]
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "power_W": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "temperature_K": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "boundary_patch": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "required": [
            "power_W"
          ],
          "properties": {
            "source_type": {
              "const": "scalarSemiImplicitSource"
            }
          }
        },
        {
          "required": [
            "temperature_K",
            "boundary_patch"
          ],
          "properties": {
            "source_type": {
              "const": "fixed_temperature_boundary"
            }
          }
        }
      ]
    }
  }
}
