{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/gmsh_C02_boundary_physical_group_contract.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: Gmsh C02 physical group and downstream boundary-role contract run config.",
  "title": "Gmsh C02 Boundary Physical Group Contract Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "gmsh",
    "backend",
    "geometry",
    "physical_groups",
    "downstream_boundary_map",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {"const": "meshing.gmsh.boundary_physical_group_contract"},
    "case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "description": {"type": "string", "minLength": 1},
    "gmsh": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_profile", "source_url"],
      "properties": {
        "runtime_profile": {"const": "physical_group_contract"},
        "source_url": {"type": "string", "minLength": 1}
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "timeout_s"],
      "properties": {
        "type": {"const": "dry_run_only"},
        "timeout_s": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_capability_id", "source_case_id", "family", "dimension", "mesh_source_policy"],
      "properties": {
        "source_capability_id": {"const": "meshing.gmsh.parametric_geometry_mesh_generation"},
        "source_case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "family": {"enum": ["rectangle_channel_2d", "extruded_rectangle_channel_3d"]},
        "dimension": {"enum": [2, 3]},
        "mesh_source_policy": {"enum": ["inline_physical_group_contract_only", "reuse_c01_generated_manifest"]}
      }
    },
    "physical_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "dimension", "role", "required", "downstream_aliases"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Za-z0-9_/-]+$"},
          "dimension": {"type": "integer", "minimum": 1, "maximum": 3},
          "role": {
            "enum": [
              "inlet",
              "outlet",
              "wall",
              "domain",
              "front_back",
              "interface",
              "symmetry"
            ]
          },
          "required": {"type": "boolean"},
          "downstream_aliases": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[A-Za-z0-9_/-]+$"},
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "downstream_boundary_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_solver", "required_roles", "role_to_boundary_type"],
      "properties": {
        "target_solver": {"enum": ["openfoam", "fenicsx", "calculix", "generic"]},
        "required_roles": {
          "type": "array",
          "items": {
            "enum": [
              "inlet",
              "outlet",
              "wall",
              "domain",
              "front_back",
              "interface",
              "symmetry"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "role_to_boundary_type": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "inlet": {"type": "string", "minLength": 1},
            "outlet": {"type": "string", "minLength": 1},
            "wall": {"type": "string", "minLength": 1},
            "domain": {"type": "string", "minLength": 1},
            "front_back": {"type": "string", "minLength": 1},
            "interface": {"type": "string", "minLength": 1},
            "symmetry": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "expected_outputs"],
      "properties": {
        "output_dir": {"type": "string"},
        "expected_outputs": {
          "type": "array",
          "items": {
            "enum": [
              "physical_group_map.json",
              "boundary_contract.json",
              "manifest.json",
              "metrics.json",
              "validation.json",
              "validation_report.md"
            ]
          },
          "minItems": 4,
          "uniqueItems": true
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "required_group_names",
        "required_roles",
        "duplicate_name_policy",
        "require_dimension_role_compatibility",
        "require_downstream_role_coverage",
        "required_manifest_sections",
        "required_artifacts"
      ],
      "properties": {
        "gate": {"enum": ["static-readiness", "smoke", "targeted-regression", "integration", "double-v", "full-regression"]},
        "required_group_names": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
        "required_roles": {
          "type": "array",
          "items": {
            "enum": [
              "inlet",
              "outlet",
              "wall",
              "domain",
              "front_back",
              "interface",
              "symmetry"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "duplicate_name_policy": {"const": "reject"},
        "require_dimension_role_compatibility": {"type": "boolean"},
        "require_downstream_role_coverage": {"type": "boolean"},
        "required_manifest_sections": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
        "required_artifacts": {
          "type": "array",
          "items": {
            "enum": [
              "physical_group_map.json",
              "boundary_contract.json",
              "manifest.json",
              "metrics.json",
              "validation.json",
              "validation_report.md"
            ]
          },
          "minItems": 4,
          "uniqueItems": true
        }
      }
    }
  }
}
