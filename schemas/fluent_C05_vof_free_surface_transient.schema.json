{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/fluent_C05_vof_free_surface_transient.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: Fluent C05 VOF mesh/setup source manifest config.",
  "title": "Fluent C05 VOF Free Surface Transient Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "source_root",
    "backend",
    "source_package",
    "setup_scope",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {"const": "cfd.fluent.vof_free_surface_transient"},
    "case_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "description": {"type": "string", "minLength": 1},
    "source_root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_root_env", "logical_path"],
      "properties": {
        "source_root_env": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "logical_path": {"type": "string", "pattern": "^(?!/)(?!.*:)(?!.*\\\\)[A-Za-z0-9_./+-]+$"}
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "archive_access"],
      "properties": {
        "type": {"enum": ["mesh_setup_manifest", "fluent_mesh_read_smoke"]},
        "archive_access": {"const": "read_only_zip"},
        "timeout_s": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "fluent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_profile", "runtime_profile_config", "vendor", "product", "version_family", "executable_env", "dimension_precision", "headless_flags", "processor_count", "journal_argument"],
      "properties": {
        "runtime_profile": {"const": "local_fluent_preflight"},
        "runtime_profile_config": {"type": "string", "minLength": 1},
        "vendor": {"const": "Ansys"},
        "product": {"const": "Fluent"},
        "version_family": {"type": "string", "minLength": 1},
        "executable_env": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "dimension_precision": {"enum": ["2ddp", "3ddp"]},
        "headless_flags": {
          "type": "array",
          "items": {"enum": ["-g"]},
          "minItems": 1,
          "uniqueItems": true
        },
        "processor_count": {"type": "integer", "minimum": 1},
        "journal_argument": {"const": "-i"}
      }
    },
    "runtime_smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mesh_entry", "journal_file", "max_warning_count", "scope"],
      "properties": {
        "mesh_entry": {"type": "string", "pattern": "^[A-Za-z0-9_./+-]+\\.msh$"},
        "journal_file": {"const": "journal.jou"},
        "max_warning_count": {"type": "integer", "minimum": 0},
        "scope": {"type": "string", "minLength": 1}
      }
    },
    "source_package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "rel_path", "package_role"],
      "properties": {
        "source_id": {"const": "C05_vof_mesh"},
        "rel_path": {"const": "Fluent_Tutorial_Package/vof.zip"},
        "package_role": {"type": "string", "minLength": 1}
      }
    },
    "setup_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_class", "readiness_scope", "future_runtime_metrics", "no_homology_claims"],
      "properties": {
        "model_class": {"type": "string", "minLength": 1},
        "readiness_scope": {"type": "string", "minLength": 1},
        "future_runtime_metrics": {"$ref": "#/$defs/non_empty_string_array"},
        "no_homology_claims": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "expected_outputs"],
      "properties": {
        "output_dir": {"type": "string", "minLength": 1},
        "expected_outputs": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "required_entry_classes", "min_mesh_entries", "required_artifacts", "no_claims"],
      "properties": {
        "gate": {"enum": ["static-readiness", "smoke"]},
        "required_entry_classes": {
          "type": "array",
          "items": {"enum": ["mesh"]},
          "minItems": 1,
          "uniqueItems": true
        },
        "min_mesh_entries": {"type": "integer", "minimum": 1},
        "required_artifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact_name"},
          "minItems": 6,
          "uniqueItems": true
        },
        "no_claims": {"$ref": "#/$defs/non_empty_string_array"}
      }
    }
  },
  "$defs": {
    "artifact_name": {
      "enum": [
        "vof_setup_manifest.json",
        "mesh_entries.json",
        "inkjet.msh",
        "journal.jou",
        "stdout.txt",
        "stderr.txt",
        "transcript.txt",
        "metrics.json",
        "validation.json",
        "validation_report.md",
        "manifest.json"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    }
  },
  "allOf": [
    {
      "if": {"properties": {"backend": {"properties": {"type": {"const": "fluent_mesh_read_smoke"}}}}},
      "then": {
        "required": ["fluent", "runtime_smoke"],
        "properties": {
          "validation": {
            "properties": {
              "gate": {"const": "smoke"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"backend": {"properties": {"type": {"const": "mesh_setup_manifest"}}}}},
      "then": {
        "properties": {
          "validation": {
            "properties": {
              "gate": {"const": "static-readiness"}
            }
          }
        }
      }
    }
  ]
}
