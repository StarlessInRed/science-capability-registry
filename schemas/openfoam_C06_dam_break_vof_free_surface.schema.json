{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_C06_dam_break_vof_free_surface.schema.json",
  "title": "OpenFOAM C06 Dam Break VOF Run Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "case_id",
    "description",
    "openfoam",
    "backend",
    "solver",
    "template",
    "geometry",
    "mesh",
    "physics",
    "initial_conditions",
    "numerics",
    "postprocess",
    "outputs",
    "validation"
  ],
  "properties": {
    "capability_id": {
      "const": "cfd.openfoam.dam_break_vof_free_surface"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "description": {
      "type": "string"
    },
    "openfoam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution",
        "version",
        "runtime_profile",
        "tutorial_path",
        "source_url",
        "bashrc_path",
        "case_layout",
        "required_executables"
      ],
      "properties": {
        "distribution": {
          "enum": [
            "openfoam_com",
            "openfoam_foundation",
            "openfoam_dev",
            "unknown"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "runtime_profile": {
          "type": "string",
          "minLength": 1
        },
        "tutorial_path": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "bashrc_path": {
          "type": "string",
          "minLength": 1
        },
        "case_layout": {
          "enum": [
            "single_region"
          ]
        },
        "required_executables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "dry_run_only",
            "wsl"
          ]
        },
        "timeout_s": {
          "type": "number"
        },
        "parallel": {
          "type": "boolean"
        },
        "wsl_distro": {
          "type": "string"
        }
      }
    },
    "solver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "mode",
        "command_sequence"
      ],
      "properties": {
        "name": {
          "const": "interFoam"
        },
        "mode": {
          "const": "transient_VOF_free_surface"
        },
        "command_sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "copy_strategy",
        "disabled_function_objects"
      ],
      "properties": {
        "source_path": {
          "type": "string"
        },
        "copy_strategy": {
          "const": "copy_official_tutorial_then_patch"
        },
        "disabled_function_objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_length_m",
        "domain_height_m",
        "thickness_m"
      ],
      "properties": {
        "domain_length_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "domain_height_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "thickness_m": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "mesh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator",
        "cell_count_scale"
      ],
      "properties": {
        "generator": {
          "const": "blockMesh"
        },
        "cell_count_scale": {
          "type": "number",
          "minimum": 1
        }
      }
    },
    "physics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gravity_m_s2",
        "water_density_kg_m3",
        "air_density_kg_m3",
        "surface_tension_N_m"
      ],
      "properties": {
        "gravity_m_s2": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "water_density_kg_m3": {
          "type": "number"
        },
        "air_density_kg_m3": {
          "type": "number"
        },
        "surface_tension_N_m": {
          "type": "number"
        }
      }
    },
    "initial_conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "water_column_width_m",
        "water_column_height_m"
      ],
      "properties": {
        "water_column_width_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "water_column_height_m": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "numerics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control"
      ],
      "properties": {
        "control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "end_time_s",
            "delta_t_s",
            "write_interval_s",
            "max_co",
            "max_alpha_co"
          ],
          "properties": {
            "end_time_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "delta_t_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "write_interval_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_co": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_alpha_co": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        }
      }
    },
    "postprocess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alpha_threshold",
        "gauge_x_m",
        "method_note"
      ],
      "properties": {
        "alpha_threshold": {
          "type": "number"
        },
        "gauge_x_m": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "method_note": {
          "type": "string"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_dir",
        "retain_generated_case",
        "expected_outputs"
      ],
      "properties": {
        "output_dir": {
          "type": "string"
        },
        "retain_generated_case": {
          "type": "boolean"
        },
        "expected_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "max_courant_number",
        "max_alpha_courant_number",
        "alpha_min_tolerance",
        "alpha_max_tolerance",
        "max_water_volume_relative_error",
        "required_generated_files",
        "required_manifest_sections",
        "matrix_role",
        "expected_trend"
      ],
      "properties": {
        "gate": {
          "enum": [
            "static-readiness",
            "smoke",
            "targeted-regression",
            "integration",
            "double-v",
            "full-regression"
          ]
        },
        "max_courant_number": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_alpha_courant_number": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "alpha_min_tolerance": {
          "type": "number"
        },
        "alpha_max_tolerance": {
          "type": "number"
        },
        "max_water_volume_relative_error": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "required_generated_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_manifest_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "matrix_role": {
          "enum": [
            "baseline",
            "mesh_refinement",
            "gravity_half",
            "water_height_125pct"
          ]
        },
        "compare_to": {
          "type": "string",
          "minLength": 1
        },
        "expected_trend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "description"
          ],
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "primary_metric": {
              "type": "string",
              "minLength": 1
            },
            "direction": {
              "type": "string",
              "minLength": 1
            },
            "threshold": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}
