{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://science-capability-registry.local/schemas/openfoam_runtime_profile.schema.json",
  "$comment": "Owner: science-capability-registry maintainers; boundary: OpenFOAM host runtime profile contract; consumer: OpenFOAM runners and evidence reviewers; failure behavior: reject missing runtime identity, backend, bashrc, case layout, and executable bindings.",
  "title": "OpenFOAM Runtime Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "distribution",
    "version_label",
    "bashrc_path",
    "case_layout",
    "backend",
    "executable_bindings",
    "required_executables",
    "tutorial_roots",
    "known_limitations"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "distribution": {
      "enum": [
        "openfoam_com",
        "openfoam_foundation",
        "openfoam_dev",
        "custom"
      ]
    },
    "version_label": {
      "type": "string",
      "minLength": 1
    },
    "bashrc_path": {
      "type": "string",
      "minLength": 1
    },
    "case_layout": {
      "enum": [
        "single_region",
        "foundation_multi_run",
        "legacy_cht_multi_region"
      ]
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "native_linux",
            "wsl",
            "docker"
          ]
        },
        "wsl_distro": {
          "type": "string",
          "minLength": 1
        },
        "timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "parallel": {
          "type": "boolean"
        },
        "docker_image": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "executable_bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "minProperties": 1
    },
    "required_executables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tutorial_roots": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "minProperties": 1
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
